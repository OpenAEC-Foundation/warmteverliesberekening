{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProjectResult",
  "description": "Complete calculation result for an entire project/dwelling.",
  "type": "object",
  "required": [
    "rooms",
    "summary"
  ],
  "properties": {
    "rooms": {
      "description": "Results per room.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/RoomResult"
      }
    },
    "summary": {
      "description": "Building-level summary.",
      "allOf": [
        {
          "$ref": "#/definitions/BuildingSummary"
        }
      ]
    }
  },
  "definitions": {
    "BuildingSummary": {
      "description": "Building-level summary of heat losses.",
      "type": "object",
      "required": [
        "collective_contribution",
        "connection_capacity",
        "total_envelope_loss",
        "total_heating_up",
        "total_neighbor_loss",
        "total_system_losses",
        "total_ventilation_loss"
      ],
      "properties": {
        "collective_contribution": {
          "description": "Contribution to collective installation in W (if applicable).",
          "type": "number",
          "format": "double"
        },
        "connection_capacity": {
          "description": "Connection capacity (aansluitvermogen) of the dwelling in W.",
          "type": "number",
          "format": "double"
        },
        "total_envelope_loss": {
          "description": "Total transmission loss through building envelope in W.",
          "type": "number",
          "format": "double"
        },
        "total_heating_up": {
          "description": "Total heating-up allowance in W.",
          "type": "number",
          "format": "double"
        },
        "total_neighbor_loss": {
          "description": "Total transmission loss to neighbors in W.",
          "type": "number",
          "format": "double"
        },
        "total_system_losses": {
          "description": "Total system losses in W.",
          "type": "number",
          "format": "double"
        },
        "total_ventilation_loss": {
          "description": "Total ventilation/infiltration loss in W.",
          "type": "number",
          "format": "double"
        }
      }
    },
    "HeatingUpResult": {
      "description": "Heating-up allowance result.",
      "type": "object",
      "required": [
        "accumulating_area",
        "f_rh",
        "phi_hu"
      ],
      "properties": {
        "accumulating_area": {
          "description": "Accumulating surface area in m².",
          "type": "number",
          "format": "double"
        },
        "f_rh": {
          "description": "Heating-up factor f_RH in W/m².",
          "type": "number",
          "format": "double"
        },
        "phi_hu": {
          "description": "Heating-up allowance Φ_hu in W.",
          "type": "number",
          "format": "double"
        }
      }
    },
    "InfiltrationResult": {
      "description": "Infiltration heat loss result.",
      "type": "object",
      "required": [
        "h_i",
        "phi_i",
        "z_i"
      ],
      "properties": {
        "h_i": {
          "description": "Specific heat loss by infiltration H_i in W/K.",
          "type": "number",
          "format": "double"
        },
        "phi_i": {
          "description": "Infiltration heat loss Φ_i in W.",
          "type": "number",
          "format": "double"
        },
        "z_i": {
          "description": "Infiltration fraction z_i.",
          "type": "number",
          "format": "double"
        }
      }
    },
    "RoomResult": {
      "description": "Calculation result for a single room.",
      "type": "object",
      "required": [
        "basis_heat_loss",
        "extra_heat_loss",
        "heating_up",
        "infiltration",
        "room_id",
        "room_name",
        "system_losses",
        "theta_i",
        "total_heat_loss",
        "transmission",
        "ventilation"
      ],
      "properties": {
        "basis_heat_loss": {
          "description": "Basis heat loss (always occurring) in W. Φ_basis = Φ_T,exterior + Φ_T,unheated + Φ_T,ground + Φ_infiltration + Φ_system",
          "type": "number",
          "format": "double"
        },
        "extra_heat_loss": {
          "description": "Extra heat loss (quadratic sum of non-simultaneous) in W. Φ_extra = √(Φ_vent² + Φ_T,adj² + Φ_hu²)",
          "type": "number",
          "format": "double"
        },
        "heating_up": {
          "description": "Heating-up allowance (opwarmtoeslag).",
          "allOf": [
            {
              "$ref": "#/definitions/HeatingUpResult"
            }
          ]
        },
        "infiltration": {
          "description": "Infiltration heat loss.",
          "allOf": [
            {
              "$ref": "#/definitions/InfiltrationResult"
            }
          ]
        },
        "room_id": {
          "description": "Room ID (matches input Room.id).",
          "type": "string"
        },
        "room_name": {
          "description": "Room name.",
          "type": "string"
        },
        "system_losses": {
          "description": "System losses (floor/wall/ceiling heating).",
          "allOf": [
            {
              "$ref": "#/definitions/SystemLossResult"
            }
          ]
        },
        "theta_i": {
          "description": "Design indoor temperature θ_i in °C.",
          "type": "number",
          "format": "double"
        },
        "total_heat_loss": {
          "description": "Total heat loss for this room in W. Φ_HL,i = Φ_basis + Φ_extra",
          "type": "number",
          "format": "double"
        },
        "transmission": {
          "description": "Transmission heat loss breakdown.",
          "allOf": [
            {
              "$ref": "#/definitions/TransmissionResult"
            }
          ]
        },
        "ventilation": {
          "description": "Ventilation heat loss.",
          "allOf": [
            {
              "$ref": "#/definitions/VentilationResult"
            }
          ]
        }
      }
    },
    "SystemLossResult": {
      "description": "System loss result (embedded heating).",
      "type": "object",
      "required": [
        "phi_ceiling_loss",
        "phi_floor_loss",
        "phi_system_total",
        "phi_wall_loss"
      ],
      "properties": {
        "phi_ceiling_loss": {
          "description": "Ceiling heating loss to exterior/adjacent Φ_verlies3 in W.",
          "type": "number",
          "format": "double"
        },
        "phi_floor_loss": {
          "description": "Floor heating loss to ground/crawlspace Φ_verlies1 in W.",
          "type": "number",
          "format": "double"
        },
        "phi_system_total": {
          "description": "Total system losses in W.",
          "type": "number",
          "format": "double"
        },
        "phi_wall_loss": {
          "description": "Wall heating loss to exterior/adjacent Φ_verlies2 in W.",
          "type": "number",
          "format": "double"
        }
      }
    },
    "TransmissionResult": {
      "description": "Breakdown of transmission heat losses for a room.",
      "type": "object",
      "required": [
        "h_t_adjacent_buildings",
        "h_t_adjacent_rooms",
        "h_t_exterior",
        "h_t_ground",
        "h_t_unheated",
        "phi_t"
      ],
      "properties": {
        "h_t_adjacent_buildings": {
          "description": "Specific heat loss to neighboring buildings H_T,ib in W/K.",
          "type": "number",
          "format": "double"
        },
        "h_t_adjacent_rooms": {
          "description": "Specific heat loss to adjacent rooms H_T,ia in W/K.",
          "type": "number",
          "format": "double"
        },
        "h_t_exterior": {
          "description": "Specific heat loss to exterior H_T,ie in W/K.",
          "type": "number",
          "format": "double"
        },
        "h_t_ground": {
          "description": "Specific heat loss to ground H_T,ig in W/K.",
          "type": "number",
          "format": "double"
        },
        "h_t_unheated": {
          "description": "Specific heat loss via unheated spaces H_T,io in W/K.",
          "type": "number",
          "format": "double"
        },
        "phi_t": {
          "description": "Total transmission heat loss Φ_T in W.",
          "type": "number",
          "format": "double"
        }
      }
    },
    "VentilationResult": {
      "description": "Ventilation heat loss result.",
      "type": "object",
      "required": [
        "f_v",
        "h_v",
        "phi_v",
        "phi_vent",
        "q_v"
      ],
      "properties": {
        "f_v": {
          "description": "Temperature correction factor f_v.",
          "type": "number",
          "format": "double"
        },
        "h_v": {
          "description": "Specific heat loss by ventilation H_v in W/K.",
          "type": "number",
          "format": "double"
        },
        "phi_v": {
          "description": "Ventilation heat loss Φ_v in W.",
          "type": "number",
          "format": "double"
        },
        "phi_vent": {
          "description": "In-scope ventilation loss Φ_vent (after subtracting infiltration) in W.",
          "type": "number",
          "format": "double"
        },
        "q_v": {
          "description": "Ventilation volume flow q_v in dm³/s.",
          "type": "number",
          "format": "double"
        }
      }
    }
  }
}