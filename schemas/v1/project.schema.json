{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project",
  "description": "Top-level project containing all input data for the calculation.",
  "type": "object",
  "required": [
    "building",
    "climate",
    "info",
    "rooms",
    "ventilation"
  ],
  "properties": {
    "building": {
      "description": "Building characteristics.",
      "allOf": [
        {
          "$ref": "#/definitions/Building"
        }
      ]
    },
    "climate": {
      "description": "Climate/design conditions.",
      "allOf": [
        {
          "$ref": "#/definitions/DesignConditions"
        }
      ]
    },
    "info": {
      "description": "Project metadata.",
      "allOf": [
        {
          "$ref": "#/definitions/ProjectInfo"
        }
      ]
    },
    "rooms": {
      "description": "All rooms in the dwelling.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/Room"
      }
    },
    "ventilation": {
      "description": "Ventilation system configuration.",
      "allOf": [
        {
          "$ref": "#/definitions/VentilationConfig"
        }
      ]
    }
  },
  "definitions": {
    "BoundaryType": {
      "description": "Type of boundary for a construction element. Determines which heat loss formula is applied.",
      "oneOf": [
        {
          "description": "Direct to outside air (ISSO 51 §2.5.1)",
          "type": "string",
          "enum": [
            "exterior"
          ]
        },
        {
          "description": "To an unheated space adjacent to the dwelling (ISSO 51 §2.5.2)",
          "type": "string",
          "enum": [
            "unheated_space"
          ]
        },
        {
          "description": "To another heated room within the same dwelling (ISSO 51 §2.5.3)",
          "type": "string",
          "enum": [
            "adjacent_room"
          ]
        },
        {
          "description": "To a neighboring dwelling/building (ISSO 51 §2.5.4)",
          "type": "string",
          "enum": [
            "adjacent_building"
          ]
        },
        {
          "description": "To the ground (ISSO 51 §2.5.5)",
          "type": "string",
          "enum": [
            "ground"
          ]
        }
      ]
    },
    "Building": {
      "description": "Building characteristics that affect the calculation.",
      "type": "object",
      "required": [
        "building_type",
        "qv10",
        "security_class",
        "total_floor_area"
      ],
      "properties": {
        "building_height": {
          "description": "Building height in m (buitenafmetingen).",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "building_type": {
          "description": "Type of building.",
          "allOf": [
            {
              "$ref": "#/definitions/BuildingType"
            }
          ]
        },
        "has_night_setback": {
          "description": "Whether night setback / operational reduction is used.",
          "default": false,
          "type": "boolean"
        },
        "num_floors": {
          "description": "Number of floors above ground.",
          "default": 1,
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "qv10": {
          "description": "Air tightness: q_v,10 value in dm³/s. Measured air volume flow at 10 Pa pressure difference.",
          "type": "number",
          "format": "double"
        },
        "security_class": {
          "description": "Security class for heat loss to neighbors.",
          "allOf": [
            {
              "$ref": "#/definitions/SecurityClass"
            }
          ]
        },
        "total_floor_area": {
          "description": "Total usable floor area (gebruiksoppervlak) A_g in m².",
          "type": "number",
          "format": "double"
        },
        "warmup_time": {
          "description": "Desired warm-up time in hours (typically 1 or 2).",
          "default": 2.0,
          "type": "number",
          "format": "double"
        }
      }
    },
    "BuildingType": {
      "description": "Building type classification.",
      "oneOf": [
        {
          "description": "Detached house",
          "type": "string",
          "enum": [
            "detached"
          ]
        },
        {
          "description": "Semi-detached house",
          "type": "string",
          "enum": [
            "semi_detached"
          ]
        },
        {
          "description": "Terraced/row house (tussenwoning)",
          "type": "string",
          "enum": [
            "terraced"
          ]
        },
        {
          "description": "End-of-terrace (hoekwoning)",
          "type": "string",
          "enum": [
            "end_of_terrace"
          ]
        },
        {
          "description": "Apartment in a porch building (portiekwoning)",
          "type": "string",
          "enum": [
            "porch"
          ]
        },
        {
          "description": "Gallery apartment (galerijwoning)",
          "type": "string",
          "enum": [
            "gallery"
          ]
        },
        {
          "description": "Stacked housing (gestapeld)",
          "type": "string",
          "enum": [
            "stacked"
          ]
        }
      ]
    },
    "ConstructionElement": {
      "description": "A single construction element forming part of a room boundary. ISSO 51 §2.5 — each element contributes to the room's heat loss.",
      "type": "object",
      "required": [
        "area",
        "boundary_type",
        "description",
        "id",
        "material_type",
        "u_value"
      ],
      "properties": {
        "adjacent_room_id": {
          "description": "ID of the adjacent room (for BoundaryType::AdjacentRoom).",
          "type": [
            "string",
            "null"
          ]
        },
        "adjacent_temperature": {
          "description": "Design temperature of the adjacent space in °C. Required for AdjacentRoom, AdjacentBuilding, UnheatedSpace.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "area": {
          "description": "Area of the element in m².",
          "type": "number",
          "format": "double"
        },
        "boundary_type": {
          "description": "Type of boundary this element faces.",
          "allOf": [
            {
              "$ref": "#/definitions/BoundaryType"
            }
          ]
        },
        "custom_delta_u_tb": {
          "description": "Custom ΔU_TB value in W/(m²·K) if not using the forfaitaire method. Overrides the default 0.1 W/(m²·K) correction.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "description": {
          "description": "Human-readable description (e.g., \"buitenwand noord\", \"raam woonkamer\").",
          "type": "string"
        },
        "ground_params": {
          "description": "Ground parameters, only for BoundaryType::Ground elements.",
          "anyOf": [
            {
              "$ref": "#/definitions/GroundParameters"
            },
            {
              "type": "null"
            }
          ]
        },
        "has_embedded_heating": {
          "description": "Whether this element has floor/wall/ceiling heating behind it. Relevant for system loss calculations (§2.9).",
          "default": false,
          "type": "boolean"
        },
        "id": {
          "description": "Unique identifier for this element.",
          "type": "string"
        },
        "material_type": {
          "description": "Material type: masonry or non-masonry. Affects thermal bridge correction in the forfaitaire method.",
          "allOf": [
            {
              "$ref": "#/definitions/MaterialType"
            }
          ]
        },
        "temperature_factor": {
          "description": "Temperature correction factor f_k (dimensionless). For exterior elements: typically 1.0. For unheated spaces: from ISSO 51 Table 4.1. For adjacent rooms: calculated from temperature difference. For neighboring dwellings: calculated with Δθ corrections. Set to `None` to have it auto-calculated.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "u_value": {
          "description": "U-value (thermal transmittance) in W/(m²·K).",
          "type": "number",
          "format": "double"
        },
        "use_forfaitaire_thermal_bridge": {
          "description": "Whether to use the forfaitaire thermal bridge correction (ΔU_TB = 0.1). Only applies to exterior boundary elements (BoundaryType::Exterior).",
          "default": true,
          "type": "boolean"
        },
        "vertical_position": {
          "description": "Vertical position: floor, ceiling, or wall. Used for fb calculation to neighboring dwellings.",
          "default": "wall",
          "allOf": [
            {
              "$ref": "#/definitions/VerticalPosition"
            }
          ]
        }
      }
    },
    "DesignConditions": {
      "description": "Design conditions for the heat loss calculation. ISSO 51 §2.7.",
      "type": "object",
      "properties": {
        "theta_b_non_residential": {
          "description": "Temperature of adjacent buildings with non-residential function in °C.",
          "default": 14.0,
          "type": "number",
          "format": "double"
        },
        "theta_b_residential": {
          "description": "Temperature of adjacent buildings with residential function θ_b in °C. Erratum 2023: 17°C for residential, 14°C for non-residential.",
          "default": 17.0,
          "type": "number",
          "format": "double"
        },
        "theta_e": {
          "description": "Design outdoor temperature θ_e in °C. Standard for the Netherlands: -10°C.",
          "default": -10.0,
          "type": "number",
          "format": "double"
        },
        "wind_factor": {
          "description": "Wind exposure factor (for infiltration correction). Typically 1.0 for normal exposure.",
          "default": 1.0,
          "type": "number",
          "format": "double"
        }
      }
    },
    "FrostProtectionType": {
      "description": "Frost protection method for heat recovery units. Determines the supply temperature θ_t (ISSO 51 Table 2.14, erratum).",
      "oneOf": [
        {
          "description": "Unknown type of frost protection",
          "type": "string",
          "enum": [
            "unknown"
          ]
        },
        {
          "description": "Reduced fan speed and/or temporary imbalance (central)",
          "type": "string",
          "enum": [
            "central_reduced_speed"
          ]
        },
        {
          "description": "Enthalpy exchanger (central, min 70% thermal efficiency)",
          "type": "string",
          "enum": [
            "central_enthalpy"
          ]
        },
        {
          "description": "Pre-heating (central)",
          "type": "string",
          "enum": [
            "central_preheating"
          ]
        },
        {
          "description": "Reduced fan speed and/or temporary imbalance (decentral)",
          "type": "string",
          "enum": [
            "decentral_reduced_speed"
          ]
        },
        {
          "description": "Enthalpy exchanger (decentral, min 70% thermal efficiency)",
          "type": "string",
          "enum": [
            "decentral_enthalpy"
          ]
        },
        {
          "description": "Pre-heating (decentral)",
          "type": "string",
          "enum": [
            "decentral_preheating"
          ]
        },
        {
          "description": "Electric pre-heating without heat recovery",
          "type": "string",
          "enum": [
            "electric_preheating"
          ]
        }
      ]
    },
    "GroundParameters": {
      "description": "Parameters for ground heat loss calculation. ISSO 51 §2.5.5, formule (4.18): H_T,ig = 1.45 × G_w × Σ(A_k × f_g2 × U_e,k)",
      "type": "object",
      "required": [
        "u_equivalent"
      ],
      "properties": {
        "fg2": {
          "description": "Temperature correction factor f_g2 (dimensionless). Accounts for seasonal ground temperature variation.",
          "default": 1.0,
          "type": "number",
          "format": "double"
        },
        "ground_water_factor": {
          "description": "Ground water correction factor G_w (dimensionless). Typically 1.0 for normal conditions, higher for high water table.",
          "default": 1.0,
          "type": "number",
          "format": "double"
        },
        "u_equivalent": {
          "description": "Equivalent U-value for the ground element U_e,k in W/(m²·K).",
          "type": "number",
          "format": "double"
        }
      }
    },
    "HeatingSystem": {
      "description": "Type of heating system installed. Affects Δθ values (Table 2.12) and system losses (§2.9).",
      "oneOf": [
        {
          "description": "Gas heater, wall-mounted heater",
          "type": "string",
          "enum": [
            "local_gas_heater"
          ]
        },
        {
          "description": "IR panels wall-mounted",
          "type": "string",
          "enum": [
            "ir_panel_wall"
          ]
        },
        {
          "description": "IR panels ceiling-mounted",
          "type": "string",
          "enum": [
            "ir_panel_ceiling"
          ]
        },
        {
          "description": "High-temperature radiators/convectors (medium temp > 50°C)",
          "type": "string",
          "enum": [
            "radiator_ht"
          ]
        },
        {
          "description": "Low-temperature radiators/convectors (medium temp ≤ 50°C)",
          "type": "string",
          "enum": [
            "radiator_lt"
          ]
        },
        {
          "description": "Ceiling heating",
          "type": "string",
          "enum": [
            "ceiling_heating"
          ]
        },
        {
          "description": "Wall heating",
          "type": "string",
          "enum": [
            "wall_heating"
          ]
        },
        {
          "description": "Baseboard/plinth heating",
          "type": "string",
          "enum": [
            "plinth_heating"
          ]
        },
        {
          "description": "Floor heating + HT radiators",
          "type": "string",
          "enum": [
            "floor_heating_with_radiator_ht"
          ]
        },
        {
          "description": "Floor heating + LT radiators",
          "type": "string",
          "enum": [
            "floor_heating_with_radiator_lt"
          ]
        },
        {
          "description": "Floor heating as main system (floor temp ≥ 27°C)",
          "type": "string",
          "enum": [
            "floor_heating_main_high"
          ]
        },
        {
          "description": "Floor heating as main system (floor temp < 27°C)",
          "type": "string",
          "enum": [
            "floor_heating_main_low"
          ]
        },
        {
          "description": "Floor + wall heating combined",
          "type": "string",
          "enum": [
            "floor_and_wall_heating"
          ]
        },
        {
          "description": "Fan-driven convectors/radiators (NEN-EN 16430)",
          "type": "string",
          "enum": [
            "fan_convector"
          ]
        }
      ]
    },
    "MaterialType": {
      "description": "Material type for thermal bridge correction. Determines whether ΔU_TB = 0.1 is applied per the forfaitaire method.",
      "oneOf": [
        {
          "description": "Masonry/stone-like materials (steenachtig)",
          "type": "string",
          "enum": [
            "masonry"
          ]
        },
        {
          "description": "Non-masonry materials like glass, doors (niet-steenachtig)",
          "type": "string",
          "enum": [
            "non_masonry"
          ]
        }
      ]
    },
    "ProjectInfo": {
      "description": "Project metadata.",
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "address": {
          "description": "Address of the building.",
          "type": [
            "string",
            "null"
          ]
        },
        "client": {
          "description": "Client name.",
          "type": [
            "string",
            "null"
          ]
        },
        "date": {
          "description": "Calculation date (ISO 8601).",
          "type": [
            "string",
            "null"
          ]
        },
        "engineer": {
          "description": "Engineer performing the calculation.",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "Project name.",
          "type": "string"
        },
        "notes": {
          "description": "Additional notes.",
          "type": [
            "string",
            "null"
          ]
        },
        "project_number": {
          "description": "Project number/reference.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Room": {
      "description": "A single room (vertrek) in the dwelling. ISSO 51 Chapter 4 — per-room heat loss calculation.",
      "type": "object",
      "required": [
        "constructions",
        "floor_area",
        "function",
        "heating_system",
        "id",
        "name",
        "ventilation_rate"
      ],
      "properties": {
        "clamp_positive": {
          "description": "Whether this room is part of a heated zone that should not have negative heat loss (i.e., minimum Φ = 0).",
          "default": true,
          "type": "boolean"
        },
        "constructions": {
          "description": "Construction elements forming the room boundaries.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/ConstructionElement"
          }
        },
        "custom_temperature": {
          "description": "Custom design indoor temperature θ_i in °C. If set, overrides the temperature from RoomFunction.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "floor_area": {
          "description": "Floor area (gebruiksoppervlak) in m². Used for ventilation rate calculations.",
          "type": "number",
          "format": "double"
        },
        "fraction_outside_air": {
          "description": "Fraction of ventilation air coming directly from outside (factor a). For rooms with both outside and internal air supply. ISSO 51 formule 4.7: H_v = 1.2 × ((a × q_v × f_v1) + (1-a) × q_v × f_v2)",
          "default": 1.0,
          "type": "number",
          "format": "double"
        },
        "function": {
          "description": "Room function determines the design indoor temperature.",
          "allOf": [
            {
              "$ref": "#/definitions/RoomFunction"
            }
          ]
        },
        "has_mechanical_exhaust": {
          "description": "Whether this room has mechanical exhaust. Affects ventilation loss calculation (formule 4.7).",
          "default": false,
          "type": "boolean"
        },
        "has_mechanical_supply": {
          "description": "Whether this room has mechanical supply.",
          "default": false,
          "type": "boolean"
        },
        "heating_system": {
          "description": "Heating system installed in this room.",
          "allOf": [
            {
              "$ref": "#/definitions/HeatingSystem"
            }
          ]
        },
        "height": {
          "description": "Room height in m.",
          "default": 2.6,
          "type": "number",
          "format": "double"
        },
        "id": {
          "description": "Unique identifier for this room.",
          "type": "string"
        },
        "internal_air_temperature": {
          "description": "Temperature of the internal air source θ_a in °C. For rooms receiving air from a hallway or other internal space.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "name": {
          "description": "Human-readable name (e.g., \"Woonkamer\", \"Slaapkamer 1\").",
          "type": "string"
        },
        "supply_air_temperature": {
          "description": "Temperature of the supply air θ_t in °C. For natural supply: θ_t = θ_e (design outdoor temperature). For mechanical supply with heat recovery: depends on system.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "ventilation_rate": {
          "description": "Ventilation volume flow rate q_v in dm³/s. From ventilation requirements (ISSO 51 Table 2.9/2.10).",
          "type": "number",
          "format": "double"
        }
      }
    },
    "RoomFunction": {
      "description": "Room function determines the design indoor temperature (θ_i). Values from ISSO 51 Table 2.11.",
      "oneOf": [
        {
          "description": "Living room / verblijfsruimte (20°C)",
          "type": "string",
          "enum": [
            "living_room"
          ]
        },
        {
          "description": "Kitchen / keuken (20°C)",
          "type": "string",
          "enum": [
            "kitchen"
          ]
        },
        {
          "description": "Bedroom / slaapkamer (20°C)",
          "type": "string",
          "enum": [
            "bedroom"
          ]
        },
        {
          "description": "Bathroom / badkamer (22°C)",
          "type": "string",
          "enum": [
            "bathroom"
          ]
        },
        {
          "description": "Toilet / toiletruimte (15°C)",
          "type": "string",
          "enum": [
            "toilet"
          ]
        },
        {
          "description": "Hallway / entree/gang (15°C)",
          "type": "string",
          "enum": [
            "hallway"
          ]
        },
        {
          "description": "Landing / overloop (15°C)",
          "type": "string",
          "enum": [
            "landing"
          ]
        },
        {
          "description": "Storage room / bergruimte (5°C if frost protection needed)",
          "type": "string",
          "enum": [
            "storage"
          ]
        },
        {
          "description": "Attic / zolder used as living space (20°C)",
          "type": "string",
          "enum": [
            "attic"
          ]
        },
        {
          "description": "Custom temperature",
          "type": "string",
          "enum": [
            "custom"
          ]
        }
      ]
    },
    "SecurityClass": {
      "description": "Security class for heat loss to neighbors. ISSO 51 Table 2.16.",
      "oneOf": [
        {
          "description": "Class A: no heat loss to neighbors assumed (c_z = 0)",
          "type": "string",
          "enum": [
            "a"
          ]
        },
        {
          "description": "Class B: moderate risk (c_z = 0.5)",
          "type": "string",
          "enum": [
            "b"
          ]
        },
        {
          "description": "Class C: high risk, neighbors may not heat (c_z = 1.0)",
          "type": "string",
          "enum": [
            "c"
          ]
        }
      ]
    },
    "VentilationConfig": {
      "description": "Building-level ventilation system configuration. ISSO 51 §2.5.7.",
      "type": "object",
      "required": [
        "system_type"
      ],
      "properties": {
        "frost_protection": {
          "description": "Frost protection type for the heat recovery unit.",
          "anyOf": [
            {
              "$ref": "#/definitions/FrostProtectionType"
            },
            {
              "type": "null"
            }
          ]
        },
        "has_heat_recovery": {
          "description": "Whether heat recovery (WTW) is installed.",
          "default": false,
          "type": "boolean"
        },
        "has_preheating": {
          "description": "Whether there is pre-heating of supply air (without WTW).",
          "default": false,
          "type": "boolean"
        },
        "heat_recovery_efficiency": {
          "description": "Heat recovery efficiency (0.0 to 1.0). E.g., 0.85 for 85% efficiency.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "preheating_temperature": {
          "description": "Pre-heating supply temperature in °C.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "supply_temperature": {
          "description": "Supply air temperature θ_t in °C after heat recovery. If not set, will be calculated from efficiency and frost protection.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "system_type": {
          "description": "Type of ventilation system (A through E).",
          "allOf": [
            {
              "$ref": "#/definitions/VentilationSystemType"
            }
          ]
        }
      }
    },
    "VentilationSystemType": {
      "description": "Ventilation system type (A through E). ISSO 51 §2.5.7.",
      "oneOf": [
        {
          "description": "System A: Natural supply and natural exhaust",
          "type": "string",
          "enum": [
            "system_a"
          ]
        },
        {
          "description": "System B: Mechanical supply and natural exhaust",
          "type": "string",
          "enum": [
            "system_b"
          ]
        },
        {
          "description": "System C: Natural supply and mechanical exhaust",
          "type": "string",
          "enum": [
            "system_c"
          ]
        },
        {
          "description": "System D: Mechanical supply and mechanical exhaust (balanced)",
          "type": "string",
          "enum": [
            "system_d"
          ]
        },
        {
          "description": "System E: Combination of systems within one dwelling",
          "type": "string",
