{
  "name": "isso51-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "generate-types": "json2ts -i ../schemas/v1/project.schema.json -o src/types/project.ts && json2ts -i ../schemas/v1/result.schema.json -o src/types/result.ts",
    "postinstall": "node -e \"const fs=require('fs');const s='node_modules/web-ifc/web-ifc.wasm';const d='public/wasm';fs.mkdirSync(d,{recursive:true});fs.copyFileSync(s,d+'/web-ifc.wasm');console.log('Copied web-ifc.wasm to public/wasm/');\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@thatopen/components": "^3.3.3",
    "@thatopen/fragments": "^3.3.6",
    "konva": "^10.2.0",
    "lucide-react": "^0.577.0",
    "oidc-spa": "^10.1.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.2.3",
    "react-router-dom": "^7.0.0",
    "three": "^0.183.2",
    "web-ifc": "^0.0.77",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  }
}
